# Babylon Environment Configuration
# Copy to .env and fill in your values

# =============================================================================
# LLM CHAT (DeepSeek cloud - primary)
# =============================================================================
DEEPSEEK_API_KEY=your-deepseek-key
LLM_API_BASE=https://api.deepseek.com
LLM_CHAT_MODEL=deepseek-chat

# Spec-111: LLM narrator at the web bridge boundary (Constitution II.5 + III.6).
# OFF by default -- DeterministicNarrator (template-based) serves the Wire feed.
# ON routes post-tick narrative generation through babylon.ai.director.NarrativeDirector.
# See web/game/narrative_service.py.
# BABYLON_LLM_NARRATOR=1

# --- Chat provider selection (program-20): deepseek | workers_ai | mock ---
LLM_PROVIDER=deepseek
# --- Cloudflare Workers AI narrator (Program 07 Decision 3; flag-off per D3) ---
# WORKERS_AI_ACCOUNT_ID=
# WORKERS_AI_TOKEN=
# WORKERS_AI_MODEL=@cf/openai/gpt-oss-20b
# WORKERS_AI_GATEWAY_ID=babylon-narrator
# WORKERS_AI_TIMEOUT=15.0

# =============================================================================
# EMBEDDINGS (Ollama local - default, no API key needed)
# =============================================================================
LLM_EMBEDDING_PROVIDER=ollama
LLM_EMBEDDING_API_BASE=http://localhost:11434
LLM_EMBEDDING_MODEL=embeddinggemma:latest

# To use OpenAI embeddings instead (cloud):
# LLM_EMBEDDING_PROVIDER=openai
# LLM_EMBEDDING_API_BASE=https://api.openai.com
# OPENAI_API_KEY=your-openai-key
# LLM_EMBEDDING_MODEL=text-embedding-ada-002

# =============================================================================
# DATABASE (SQLite - reference data; spec-061/062/064)
# =============================================================================
DATABASE_URL=sqlite:///babylon.db

# =============================================================================
# POSTGRES (runtime + tests; spec-061/062/064)
# =============================================================================
# Default points at the local docker test container started by
# `mise run db:bootstrap` (creates babylon-pg-isolated on port 5433).
# Override for a different deployment.
#
# - BABYLON_PG_DSN: the DSN the headless runner reads at runtime
#   (mise run sim:e2e-michigan, python -m babylon.engine.headless_runner).
# - BABYLON_TEST_PG_DSN: fallback DSN for integration tests
#   (tests/integration/test_*.py). Keep identical to BABYLON_PG_DSN for the
#   default dev loop; override in CI if you point at a separate test DB.
# - PGPASSWORD: libpq client convention; matches the DSN password so direct
#   psql inspections work without retyping the password.

BABYLON_PG_DSN=host=localhost port=5433 dbname=babylon_test user=test password=test
BABYLON_TEST_PG_DSN=host=localhost port=5433 dbname=babylon_test user=test password=test
PGPASSWORD=test

# BABYLON_SLOW_TESTS is intentionally NOT set here — it gates the heavyweight
# wallclock-budget + CI clean-run gates (T051, T056) behind explicit opt-in.
# Run those with:
#   BABYLON_SLOW_TESTS=1 mise run test:int

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
DEBUG=false
TESTING=false
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_DIR=./logs

# =============================================================================
# METRICS & PERFORMANCE
# =============================================================================
METRICS_ENABLED=true
METRICS_INTERVAL=60

# =============================================================================
# RATE LIMITING (for cloud APIs)
# =============================================================================
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0
LLM_RATE_LIMIT_RPM=60
LLM_BATCH_SIZE=8
LLM_REQUEST_TIMEOUT=30.0

# =============================================================================
# LEGACY (OpenAI-specific, for backward compatibility)
# =============================================================================
# OPENAI_API_KEY=your-openai-key
# OPENAI_ORGANIZATION_ID=optional-org-id
