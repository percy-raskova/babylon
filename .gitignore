# ChromaDB local storage
chromadb/

# Tool Configuration
.continue*
.continuerules
.continuerc.json

*.pyc

#pycache
*__pycache__*
.mypy_cache/
.pytest_cache/
.ruff_cache/
.venv/


.coverage

# Hypothesis property-based testing cache
.hypothesis/

# Compiled Audio (generated from MIDI via FluidSynth)
# Commit MIDI source files, not compiled audio
assets/audio/
*.wav
*.mp3
*.ogg

# Large image assets (use Git LFS for these)
assets/images/*.png

# Analysis results (regenerated by mise tasks)
results/

# Mutation testing (mutmut cache and working directory)
mutants/
.mutmut-cache/
html/

# Claude Code local settings
.claude/settings.local.json
assets/images/prolewiki.zip

# Percy's personal research materials (PDFs, theory texts)
thoughts/percy/

# Data directory (API responses, databases - too large for git)
/data/

# DOT transportation data files (large, downloaded on-demand)
src/babylon/data/dot/*.csv
src/babylon/data/dot/*.geodatabase
src/babylon/data/dot/*.json

# Test coverage output
coverage.json

.mypy_cache/

# Large binary assets (stored externally)
assets/
