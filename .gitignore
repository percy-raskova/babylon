# Virtual Environment
.env*
.venv-babylon*

# IDE
.vscode*
.aider*
.continue*

# Node
node_modules
.node

# Environment Variables & Secrets
.env
*.env
.env.local
.env.development
.env.test
.env.production
.envrc
# The template is the one env file that MUST stay tracked (matched by .env* above)
!.env.example

# Session transcripts / agent logs — may contain secrets pasted into context.
# NEVER commit: a Cloudflare API token leaked via sessions/session-ses_0d18.md
# on 2026-07-08 (owner-queue #22). The file is now untracked; rotate the token.
sessions/
.dev.vars
.dev.vars.*

# Logs and Databases
*.log
logs/
*.sqlite3
*.db
data/babylon.db
data/*.db
# Note: /data/ at root is ignored below (line 77). Don't add bare "data/" here
# as it would also ignore src/babylon/data/ source code.

# ChromaDB local storage
chromadb/

# Tool Configuration
.continue*
.continuerules
.continuerc.json

*.pyc

#pycache
*__pycache__*
.pytest_cache/
.ruff_cache/
.venv/
.coverage

# Hypothesis property-based testing cache
.hypothesis/

# Compiled Audio (generated from MIDI via FluidSynth)
# Commit MIDI source files, not compiled audio
assets/audio/
*.wav
*.mp3
*.ogg

# Large image assets (use Git LFS for these)
assets/images/*.png

# Analysis results (regenerated by mise tasks)
results/

# Test reports (verbose machine-readable artifacts; one subdir per mise test:* task)
reports/test-results/
# Ingest audit reports + per-run sim artifacts (regenerable byproducts)
reports/ingest/
reports/sim-runs/
# Daemonized sim pidfiles/logs (sim:e2e-bg)
.sim-pids/

# Coverage HTML output (pyproject.toml's --cov-report=html default; landed locally before)
htmlcov/

# Mutation testing (mutmut cache and working directory)
mutants/
.mutmut-cache/
html/

# Web app dev server PIDs and logs (mise run web:dev)
.web-pids/

# Claude Code local settings
.claude/settings.local.json
.claude/scheduled_tasks.lock
assets/images/prolewiki.zip
.claude/worktrees/

# Percy's personal research materials (PDFs, theory texts)
project/notes/percy/

# Data directory (API responses, databases - too large for git)
/data/

# DOT transportation data files (large, downloaded on-demand)
src/babylon/data/dot/*.csv
src/babylon/data/dot/*.geodatabase
src/babylon/data/dot/*.json

# Test coverage output
coverage.json
assets/images/ff-template.zip
assets/images/templates.zip
deploy/ansible-setup-guide.md

# node
.node
.pgdata
node_modules

# Tool Caches
.pre-commit-cache/
.playwright-mcp/
# Superpowers plugin working state (was local-only in .git/info/exclude; shared
# here so the repo-hygiene gate sees the same ignore set locally and in CI)
.superpowers/

# One-off tool dumps (regenerable; were briefly tracked pre-Program-14)
pytest_out.txt
ast_usages.txt

# Claude's scratch space (ai/ tree is Claude-owned; scratch contents are ephemeral)
ai/scratch/*
!ai/scratch/README.md

# ai/_inbox is the owner's drop-zone (parsed items → ai/_inbox/archive/). Keep the
# text notes tracked, but babylon_books/ is 555 MB of reference PDFs — never commit it.
ai/_inbox/babylon_books/

# Frontend (src/frontend — the cockpit, spec-110/112)
dev_harness.png
test_hang.py
src/frontend/dist/
src/frontend/coverage/
src/frontend/playwright-report/
src/frontend/test-results/

# design-sync (claude.ai/design converter) — staged scripts, build output,
# machine state. The durable set (.design-sync/{config.json,NOTES.md,
# conventions.md,fonts.css,previews/,overrides/}) IS committed.
.ds-sync/
ds-bundle/
.design-sync/.cache/
.design-sync/learnings/
.design-sync/node_modules

# Deployment secrets (NEVER commit)
deploy/terraform/terraform.tfvars
deploy/terraform/.terraform/
deploy/terraform/*.tfstate
deploy/terraform/*.tfstate.backup
deploy/ansible/.vault_pass
deploy/ansible/production_inventory.yml
