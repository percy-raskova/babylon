---
# EXAMPLE ONLY — Do NOT commit the real vault.yml
# Create the actual vault with:
#   ansible-vault create group_vars/production/vault.yml
#
# Then populate it with these keys:

vault_django_secret_key: "<generated-64-char-random-string>"
vault_db_password: "<generated-32-char-random-string>"
vault_r2_access_key_id: "<from-cloudflare-r2-api-tokens>"
vault_r2_secret_access_key: "<from-cloudflare-r2-api-tokens>"
vault_r2_account_id: "<from-cloudflare-dashboard>"
vault_ssl_crt: |
  -----BEGIN CERTIFICATE-----
  <Cloudflare Origin CA certificate PEM>
  -----END CERTIFICATE-----
vault_ssl_key: |
  -----BEGIN PRIVATE KEY-----
  <Cloudflare Origin CA private key PEM>
  -----END PRIVATE KEY-----
