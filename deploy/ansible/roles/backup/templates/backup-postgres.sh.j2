#!/bin/bash
set -euo pipefail

DATE=$(date +%Y-%m-%d)
DUMP_FILE="{{ backup_tmp_dir }}/babylon-${DATE}.sql.zst"

sudo -u postgres pg_dump {{ db_name | quote }} | zstd -9 > "${DUMP_FILE}"
rclone copy "${DUMP_FILE}" {{ rclone_remote_name }}:{{ r2_backup_bucket }}/daily/
rm -f "${DUMP_FILE}"

echo "Backup completed: babylon-${DATE}.sql.zst"
