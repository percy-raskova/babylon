# Hetzner VPS Provisioning - Example Configuration
# Copy this file to terraform.tfvars and fill in your values

# ============================================
# HETZNER API TOKEN (Required)
# ============================================
# Get from: https://console.hetzner.cloud/ → Project → Security → API tokens
hcloud_token = "your_hetzner_api_token_here"

# ============================================
# CLOUDFLARE (Required)
# ============================================
# Token scopes: Zone DNS Edit, Zone SSL and Certificates Edit, Account R2 Edit
cloudflare_api_token   = "your_cloudflare_api_token_here"
cloudflare_account_id  = "your_cloudflare_account_id_here"
cloudflare_zone_id     = "your_cloudflare_zone_id_here"
cloudflare_zone_name   = "percypedia.biz"
cloudflare_record_name = "babylon"

# ============================================
# PROJECT CONFIGURATION
# ============================================
project_name = "babylon"    # Used for resource naming
environment  = "production" # dev, staging, or production

# ============================================
# SSH CONFIGURATION
# ============================================
ssh_key_name        = "babylon-ssh-key"
ssh_public_key_path = "~/.ssh/id_ed25519.pub" # Path to your public key

# ============================================
# SECURITY
# ============================================
# IMPORTANT: Replace with your actual IP address!
# Get your IP: curl ifconfig.me
ssh_allowed_ips = ["YOUR.HOME.IP/32"]

# Optional: Enable Dokploy port (3000)
enable_dokploy_port = false
dokploy_allowed_ips = ["0.0.0.0/0"]

# Optional: Custom ports
# custom_tcp_ports = [
#   {
#     port        = "5432"
#     allowed_ips = ["10.0.0.0/8"]
#   },
#   {
#     port        = "8080"
#     allowed_ips = ["0.0.0.0/0"]
#   }
# ]

# ============================================
# SERVER CONFIGURATION
# ============================================
server_count    = 1      # Number of VPS servers
server_type     = "cx32" # Target: 4 vCPU, 8GB RAM, 80GB disk
server_image    = "debian-13"
server_location = "ash"

# Optional: Server labels
# server_labels = {
#   team        = "devops"
#   application = "web"
# }

# ============================================
# NETWORKING
# ============================================
enable_private_network   = false
private_network_ip_range = "10.0.0.0/16"
private_subnet_ip_range  = "10.0.1.0/24"
network_zone             = "us-east"

# ============================================
# STORAGE
# ============================================
enable_additional_storage = false
storage_size_gb           = 50 # 10-10000 GB

# ============================================
# LOAD BALANCER
# ============================================
enable_load_balancer = false
load_balancer_type   = "lb11" # lb11, lb21, lb31
