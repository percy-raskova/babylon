{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "A cultural group",
  "$id": "https://babylonrpg.com/schemas/entities/culture.schema.json",
  "title": "Culture",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "values": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "customs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "attributes": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "required": [
    "id",
    "name"
  ],
  "additionalProperties": true
}
