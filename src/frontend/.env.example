# Cockpit dev/e2e environment — copy to `.env` (gitignored, like every
# .env* except this template) and adjust per machine. Precedence, highest
# first: shell environment > .env.local > .env > the in-code defaults
# shown here. Read by vite.config.ts and playwright.config.ts via Vite's
# loadEnv.

# Port the Vite dev server / e2e suite use (playwright.config.ts starts or
# reuses the server here). The B6 precedent uses 5180 when 5173 is
# squatted by another checkout's dev server.
COCKPIT_E2E_PORT=5173

# Django backend the Vite proxy forwards /api, /accounts, /health to.
# Point at e.g. http://localhost:8001 when a second checkout/worktree runs
# its own backend beside the canonical :8000 one.
COCKPIT_BACKEND_URL=http://localhost:8000
